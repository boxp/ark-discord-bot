{
  extends: [
    'config:recommended',
    'github>suzuki-shunsuke/renovate-config#4.0.0',
  ],
  labels: [
    'renovate:{{depName}}',
    'renovate:{{depName}}/{{newVersion}}',
    'datasource:{{datasource}}',
  ],
  major: {
    automerge: false,
  },
  prHourlyLimit: 10,
  prConcurrentLimit: 10,
  branchConcurrentLimit: 20,
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/^.github/workflows/.*\\.ya?ml$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)\\s+env:\\s+[A-Z_]+_VERSION:\\s*["\']?(?<currentValue>[^"\'\\s]+)["\']?',
      ],
    },
  ],
  packageRules: [
    {
      additionalBranchPrefix: '{{packageFileDir}}-',
      commitMessageSuffix: '({{packageFileDir}})',
      matchPackageNames: [
        '/.*/',
      ],
    },
  ],
}
